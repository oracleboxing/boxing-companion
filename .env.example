# Boxing Companion local environment template
# Copy this to .env for local scripts/tools, or into your local AI/Codex context.
# Do not commit .env.

# Supabase, existing Oracle Boxing project
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Never put the service role key in the iOS app.
# SUPABASE_SERVICE_ROLE_KEY=DO_NOT_USE_IN_IOS_APP

# App identifiers
APP_NAME=Boxing Companion
APP_DISPLAY_NAME=Boxing Companion
APP_BRAND_NAME=Oracle Boxing
APP_BUNDLE_ID=com.oracleboxing.boxingcompanion

# Product flags
USE_CLOUDKIT=false
LOCAL_STORAGE=SwiftData
CLOUD_SOURCE_OF_TRUTH=Supabase
TESTING_SYSTEM=Swift Testing + XCUITest

# First build focus
PRIMARY_CTA=Start Workout
MVP_MODE=local_runner_first
